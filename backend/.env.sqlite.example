# Local development — SQLite (no Docker). See scripts/use-local-dev.ps1
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="local-dev-jwt-secret-not-for-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="local-dev-refresh-secret-not-for-production"
JWT_REFRESH_EXPIRES_IN="30d"
WEB_ORIGIN="http://localhost:3001,http://127.0.0.1:3001,http://localhost:3000"
PORT=3000
FCM_SERVER_KEY=""
ATTENDANCE_LOCK_HOURS=48

  occurrence OperationOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  planEntry  ChoirSchedulePlanEntry? @relation(fields: [planEntryId], references: [id], onDelete: SetNull)
  adjustments ChoirScheduleAdjustment[]

  @@unique([choirId, occurrenceId, role])
  @@index([occurrenceId])
  @@index([choirId])
  @@index([status])
}

enum ChurchScheduleScopeType {
  MINISTRY
  CHOIR
  PROTOCOL
  OPERATIONAL_UNIT
}

enum ChurchScheduleActivityType {
  PRAYER
  REHEARSAL
  MEETING
  TRAINING
  CONCERT
  FELLOWSHIP
  OTHER_CHURCH_FACING
}

enum ChurchScheduleSubmissionStatus {
  DRAFT
  SUBMITTED
  AUTO_PUBLISHED
  CONFLICT_HELD
  ADMIN_PUBLISHED
  REJECTED
  CANCELLED
  COUNTER_PROPOSED
}

enum ChurchScheduleEntrySource {
  CHURCH_DIRECT
  AUTO_PUBLISHED
  ADMIN_PUBLISHED
  OVERRIDE
}

/// Church room / space catalog for master schedule conflict detection (Phase A).
model ChurchFacility {
  id                  String   @id @default(uuid())
  code                String   @unique
  name                String
  building            String?
  floor               String?
  capacity            Int?
  requiresAdminNotify Boolean  @default(false)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  scheduleSubmissions ChurchScheduleSubmission[]
  scheduleEntries     ChurchScheduleEntry[]

  @@index([isActive, sortOrder])
}

/// Submitted activity request (draft → submit → auto-publish or conflict hold).
model ChurchScheduleSubmission {
  id                    String                       @id @default(uuid())
  scopeType             ChurchScheduleScopeType
  scopeId               String
  title                 String
  activityType          ChurchScheduleActivityType
  calendarDate          DateTime
  startAt               DateTime
  endAt                 DateTime
  facilityId            String
  purpose               String?
  weekOf                DateTime?
  notes                 String?
  status                ChurchScheduleSubmissionStatus @default(DRAFT)
  submittedByUserId     String?
  submittedAt           DateTime?
  conflictEntryId       String?
  conflictReason        String?
  suggestedAlternatives Json?
  rejectionReason       String?
  counterProposal       Json?
  createdByUserId       String
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  facility ChurchFacility       @relation(fields: [facilityId], references: [id])
  entry    ChurchScheduleEntry?

  @@index([scopeType, scopeId])
  @@index([status])
  @@index([facilityId])
  @@index([startAt, endAt])
  @@index([createdByUserId])
}

/// Published row on the church master timetable.
model ChurchScheduleEntry {
  id              String                    @id @default(uuid())
  source          ChurchScheduleEntrySource
  scopeType       ChurchScheduleScopeType?
  scopeId         String?
  title           String
  activityType    ChurchScheduleActivityType
  startAt         DateTime
  endAt           DateTime
  facilityId      String
  purpose         String?
  isChurchBlock   Boolean                   @default(false)
  overrideReason  String?
  submissionId    String?                   @unique
  createdByUserId String
  cancelledAt     DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  facility   ChurchFacility            @relation(fields: [facilityId], references: [id])
  submission ChurchScheduleSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([facilityId, startAt, endAt])
  @@index([startAt, endAt])
  @@index([cancelledAt])
}

model ChurchServiceRequest {
  id                String                     @id @default(uuid())
  occurrenceId      String
  preferredChoirId  String?
  assignedChoirId   String?
  role              ChoirServiceAssignmentRole @default(PRIMARY)
  title             String?
  notes             String?
  status            ChurchServiceRequestStatus @default(PENDING)
  requestedByUserId String
  reviewedByUserId  String?
  reviewedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  occurrence     OperationOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  preferredChoir Choir?              @relation("ChurchServiceRequestPreferred", fields: [preferredChoirId], references: [id], onDelete: SetNull)
  assignedChoir  Choir?              @relation("ChurchServiceRequestAssigned", fields: [assignedChoirId], references: [id], onDelete: SetNull)

  @@index([occurrenceId])
  @@index([status])
  @@index([assignedChoirId])
}

model ServicePreparationPlan {
  id              String         @id @default(uuid())
  choirId         String
  occurrenceId    String
  uniformNotes    String?
  pepTalkTitle    String?
  pepTalkAt       DateTime?
  pepTalkTiming   PepTalkTiming?
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  choir      Choir                    @relation(fields: [choirId], references: [id], onDelete: Cascade)
  occurrence OperationOccurrence      @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  occurrenceId   String
  role           ChoirServiceAssignmentRole @default(PRIMARY)
  status         ChoirServiceAssignmentStatus @default(PENDING_CHURCH_CONFIRMATION)
  source         ChoirServiceAssignmentSource @default(CHOIR_PROPOSED)
  assignedById   String?
  proposedById   String?
  confirmedById  String?
  confirmedAt    DateTime?
  rejectedById   String?
  rejectedAt     DateTime?
  rejectionReason String?
  assignedAt     DateTime                   @default(now())
  overrideReason String?
  bypassRules    Boolean                    @default(false)
  conflictReason String?
  choirAcceptedById String?
  choirAcceptedAt   DateTime?
  announcedAt    DateTime?
  cancelledAt    DateTime?

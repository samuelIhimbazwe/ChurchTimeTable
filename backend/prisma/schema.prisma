  PRESENT_LATE
  PRESENT_LATE_LEFT_EARLY
  ABSENT_EXCUSED
  ABSENT_SELF_REPLACED
  ABSENT_UNEXCUSED
}

enum ProtocolRankingCategory {
  ATTENDANCE
  RELIABILITY
  SERVICE_COUNT
  REPLACEMENT_SUPPORT
  TEAMWORK
  OVERALL
}

enum ProtocolReplacementStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProtocolAssignmentMode {

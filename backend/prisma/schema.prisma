  TEAM_SUPPORTER
  RELIABLE_MEMBER
  MOST_ACTIVE
  PERFECT_ATTENDANCE
  SERVICE_VETERAN
  ATTENDANCE_CHAMPION
}

model ProtocolEngineSettings {
  id                          String   @id @default("default")
  maxOfficialServicesPerMonth Int      @default(3)
  maxNonChoirMembers          Int      @default(3)
  backupPoolSize              Int      @default(3)
  gradePresentFull            Int      @default(100)
  gradePresentLate            Int      @default(80)
  gradePresentLeftEarly       Int      @default(75)
  gradePresentLateLeftEarly   Int      @default(50)
  gradeAbsentSelfReplaced     Int      @default(40)
  gradeAbsentExcused          Int      @default(20)
  gradeAbsentUnexcused        Int      @default(0)
  overallWeightAttendance     Float    @default(0.3)
  overallWeightReliability    Float    @default(0.3)
  overallWeightServiceCount   Float    @default(0.2)
  overallWeightReplacement    Float    @default(0.1)
  overallWeightTeamwork       Float    @default(0.1)
  membersCanViewFullRanking   Boolean  @default(false)
  updatedAt                   DateTime @updatedAt
}

model ProtocolMemberProfile {
  id                          String   @id @default(uuid())
  memberId                    String   @unique
  protocolUnitId              String
  active                      Boolean  @default(true)
  notes                       String?
  officialServicesMonth       Int      @default(0)
  extraServicesMonth          Int      @default(0)
  totalServicesMonth          Int      @default(0)
  lifetimeOfficialServices    Int      @default(0)
  lifetimeExtraServices       Int      @default(0)
  lifetimeTotalServices       Int      @default(0)
  assignedCount               Int      @default(0)
  attendedCount               Int      @default(0)
  attendanceRate              Float    @default(0)
  lateArrivals                Int      @default(0)
  earlyDepartures             Int      @default(0)
  excusedAbsences             Int      @default(0)
  replacementFoundAbsences    Int      @default(0)
  selfReplacements            Int      @default(0)
  unexcusedAbsences           Int      @default(0)
  replacementServicesAccepted Int      @default(0)
  replacementAssistanceGiven  Int      @default(0)
  reliabilityScore            Float    @default(100)
  currentRank                 Int?
  currentGradeScore           Float?
  currentOverallRank          Int?
  statsMonth                  Int?
  statsYear                   Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  member       Member              @relation(fields: [memberId], references: [id], onDelete: Cascade)
  protocolUnit OperationalUnit     @relation(fields: [protocolUnitId], references: [id], onDelete: Restrict)
  badges       ProtocolMemberBadge[]

  @@index([protocolUnitId, active])
  @@index([currentRank])
}

model ProtocolOccurrenceTeam {
  id                String                       @id @default(uuid())
  occurrenceId      String                       @unique
  status            ProtocolOccurrenceTeamStatus @default(GENERATED)
  assignmentMode    ProtocolAssignmentMode
  generatedAt       DateTime                     @default(now())
  reviewedAt        DateTime?
  approvedAt        DateTime?
  publishedAt       DateTime?
  completedAt       DateTime?
  generatedByUserId String?
  approvedByUserId  String?
  notes             String?

  occurrence  OperationOccurrence            @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  members     ProtocolOccurrenceTeamMember[]
  teamLeaders ProtocolOccurrenceTeamLeader[]
  backups     ProtocolOccurrenceTeamBackup[]
  report     ProtocolTeamReport?

  @@index([status])
  @@index([generatedAt])
}

model ProtocolTeamLeader {
  id               String   @id @default(uuid())
  memberId         String   @unique
  choirId          String?
  label            String?
  isNonChoirLeader Boolean  @default(false)
  active           Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  member           Member                         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  choir            Choir?                         @relation(fields: [choirId], references: [id], onDelete: SetNull)
  teamAssignments  ProtocolOccurrenceTeamLeader[]
  reportsSubmitted ProtocolTeamReport[]

  @@index([choirId, active])
  @@index([isNonChoirLeader, active])
}

model ProtocolOccurrenceTeamLeader {
  id                   String   @id @default(uuid())
  teamId               String
  protocolTeamLeaderId String
  assignedByUserId     String?
  overrideReason       String?
  assignedAt           DateTime @default(now())

  team               ProtocolOccurrenceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  protocolTeamLeader ProtocolTeamLeader     @relation(fields: [protocolTeamLeaderId], references: [id], onDelete: Restrict)

  @@unique([teamId, protocolTeamLeaderId])
  @@index([protocolTeamLeaderId])
}

model ProtocolOccurrenceTeamBackup {
  id        String   @id @default(uuid())
  teamId    String
  memberId  String
  rank      Int      @default(0)
  createdAt DateTime @default(now())

  team   ProtocolOccurrenceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId, rank])
}

model ProtocolTeamReport {
  id              String   @id @default(uuid())
  teamId          String   @unique
  leaderId        String
  summary         String
  issues          String?
  recommendations String?
  submittedAt     DateTime @default(now())
  submittedByUserId String?

  team   ProtocolOccurrenceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leader ProtocolTeamLeader     @relation(fields: [leaderId], references: [id], onDelete: Restrict)

  @@index([submittedAt])
}

model ProtocolOccurrenceTeamMember {
  id                    String                 @id @default(uuid())
  teamId                String
  memberId              String
  assignmentType        ProtocolTeamMemberType @default(OFFICIAL)
  isExtraService        Boolean                @default(false)
  quotaOverrideReason   String?
  quotaOverrideByUserId String?
  createdAt             DateTime               @default(now())

  team                ProtocolOccurrenceTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member              Member                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  attendance          ProtocolTeamAttendance?
  replacementRequests ProtocolReplacementRequest[]

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

model ProtocolTeamAttendance {
  id                    String                    @id @default(uuid())
  teamMemberId          String                    @unique
  outcome               ProtocolAttendanceOutcome
  attendanceScoreEarned Int?
  recordedAt            DateTime                  @default(now())
  recordedByUserId      String
  notes                 String?

  teamMember ProtocolOccurrenceTeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@index([recordedAt])
  @@index([outcome])
}

model ProtocolReplacementRequest {
  id                  String                    @id @default(uuid())
  teamMemberId        String
  originalMemberId    String
  replacementMemberId String
  reason              String?
  status              ProtocolReplacementStatus @default(PENDING)
  reviewedByUserId      String?
  reviewedAt          DateTime?
  createdAt           DateTime                  @default(now())

  teamMember        ProtocolOccurrenceTeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  originalMember    Member                       @relation("ProtocolReplacementOriginal", fields: [originalMemberId], references: [id], onDelete: Restrict)
  replacementMember Member                       @relation("ProtocolReplacementCover", fields: [replacementMemberId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([teamMemberId])
  @@index([originalMemberId])
}

model ProtocolRankingEntry {
  id               String   @id @default(uuid())
  memberId         String
  year             Int
  month            Int?
  rank             Int
  gradeScore       Float
  totalServices    Int
  attendanceRate   Float
  reliabilityScore Float
  generatedAt      DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, year, month])
  @@index([year, month, rank])
}

model ProtocolMemberBadge {
  id        String            @id @default(uuid())
  profileId String
  kind      ProtocolBadgeKind
  awardedAt DateTime          @default(now())
  year      Int?
  month     Int?

  profile ProtocolMemberProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, kind, year, month])
  @@index([profileId])
}

model ProtocolCategoryRankingEntry {
  id        String                  @id @default(uuid())
  memberId  String
  category  ProtocolRankingCategory
  year      Int
  month     Int?
  rank      Int
  score     Float
  generatedAt DateTime              @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, category, year, month])
  @@index([category, year, month, rank])
}


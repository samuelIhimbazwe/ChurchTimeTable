  role           ChoirServiceAssignmentRole @default(PRIMARY)
  isOverride     Boolean                    @default(false)
  overrideReason String?
  sortOrder      Int                        @default(0)

  plan        ChoirSchedulePlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  assignments ChoirServiceAssignment[]

  @@unique([planId, occurrenceId, choirId, role])
  @@index([occurrenceId])
}

model ChoirScheduleAdjustment {
  id              String                      @id @default(uuid())
  occurrenceId    String
  choirId         String?
  assignmentId    String?
  action          ChoirScheduleAdjustmentAction
  previousChoirId String?
  newChoirId      String?
  reason          String?
  actorUserId     String
  createdAt       DateTime                    @default(now())

  assignment ChoirServiceAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([occurrenceId])
  @@index([createdAt])
}

model ChoirCategoryRankingEntry {
  id        String               @id @default(uuid())
  choirId   String
  memberId  String
  category  ChoirRankingCategory
  year      Int
  month     Int?
  rank      Int
  score     Float
  generatedAt DateTime           @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([choirId, memberId, category, year, month])
  @@index([choirId, category, year, month, rank])
}

model ChoirMemberBadge {
  id        String         @id @default(uuid())
  profileId String
  kind      ChoirBadgeKind
  awardedAt DateTime       @default(now())
  year      Int?
  month     Int?

  profile ChoirMemberParticipationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, kind, year, month])
  @@index([profileId])
}

// --- Member Portal (MEMBER-PORTAL-1) ---

enum ChurchBroadcastType {
  LIVE_SERVICE
  RECORDED_SERVICE
  SERMON
  SPECIAL_EVENT
  OTHER
}

model ChurchBroadcast {
  id            String              @id @default(uuid())
  title         String
  description   String?
  youtubeUrl    String
  thumbnail     String?
  broadcastType ChurchBroadcastType @default(OTHER)
  startAt       DateTime?
  endAt         DateTime?
  isLive        Boolean             @default(false)
  publishedAt   DateTime?
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  createdBy User @relation("BroadcastCreator", fields: [createdById], references: [id])

  @@index([isLive])
  @@index([broadcastType])
  @@index([startAt])
}

enum ChoirJoinRequestType {
  VISITOR
  PERMANENT_MEMBER
  RETURNING_MEMBER
  OTHER
}

enum ChoirJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
  NEEDS_INFO
}

model ChoirJoinRequest {
  id               String                 @id @default(uuid())
  memberId         String
  choirId          String
  requestType      ChoirJoinRequestType   @default(PERMANENT_MEMBER)
  reason           String?
  status           ChoirJoinRequestStatus @default(PENDING)
  reviewNotes      String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  member         Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  choir          Choir  @relation(fields: [choirId], references: [id], onDelete: Cascade)
  reviewedByUser User?  @relation("ChoirJoinReviewerUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([choirId, status])
  @@index([memberId, status])
}

enum ChoirSponsorRequestKind {
  NEW_SPONSOR
  EXISTING_SPONSOR
}

enum ChoirSponsorRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model ChoirSponsorRequest {
  id               String                    @id @default(uuid())
  memberId         String
  choirId          String
  kind             ChoirSponsorRequestKind
  message          String?
  status           ChoirSponsorRequestStatus @default(PENDING)
  reviewNotes      String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  member         Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  choir          Choir  @relation(fields: [choirId], references: [id], onDelete: Cascade)
  reviewedByUser User?  @relation("ChoirSponsorReviewerUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([choirId, status])
  @@index([memberId, status])
}

model ChoirSponsorship {
  id               String    @id @default(uuid())
  memberId         String
  choirId          String
  active           Boolean   @default(true)
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  approvedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  choir  Choir  @relation(fields: [choirId], references: [id], onDelete: Cascade)

  @@unique([memberId, choirId])
  @@index([choirId, active])
  @@index([memberId, active])
}

enum ProtocolInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model ProtocolInvitation {
  id          String                   @id @default(uuid())
  memberId    String
  invitedById String
  message     String?
  status      ProtocolInvitationStatus @default(PENDING)
  expiresAt   DateTime
  respondedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  member    Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  invitedBy Member @relation("ProtocolInviter", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([memberId, status])
  @@index([status])
}

enum ProtocolMembershipClaimStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model ProtocolMembershipClaim {
  id           String                        @id @default(uuid())
  memberId     String
  message      String?
  status       ProtocolMembershipClaimStatus @default(PENDING)
  reviewNotes  String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  member     Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reviewedBy Member? @relation("ProtocolClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([memberId, status])
  @@index([status])
}

// --- Pilot readiness (PILOT-READY-1) ---

enum ImportJobType {
  MEMBERS
  CHOIR_MEMBERS
  PROTOCOL_MEMBERS
  MINISTRIES
  MINISTRY_MEMBERS
  LEADERSHIP_ASSIGNMENTS
  ASSETS
  SCHEDULES
}

enum ImportJobStatus {
  PENDING
  PREVIEWING
  CONFIRMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model ImportJob {
  id           String          @id @default(uuid())
  type         ImportJobType
  status       ImportJobStatus @default(PENDING)
  fileName     String?
  mimeType     String?
  uploadedById String
  preview      Json?
  results      Json?
  errorMessage String?
  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([status])
  @@index([type])
  @@index([uploadedById])
}

enum NotificationRuleTrigger {
  SERVICE_TOMORROW
  SERVICE_TODAY
  REHEARSAL_TOMORROW
  REHEARSAL_TODAY
  EVENT_REMINDER
  PROTOCOL_ASSIGNMENT
  CHOIR_ASSIGNMENT
  SCHEDULE_CHANGE
  REPLACEMENT_APPROVED
  INVITATION_RECEIVED
  REQUEST_APPROVED
  REQUEST_REJECTED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ReminderJobStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

model NotificationRule {
  id            String                  @id @default(uuid())
  trigger       NotificationRuleTrigger @unique
  channel       NotificationChannel     @default(IN_APP)
  enabled       Boolean                 @default(true)
  titleTemplate String?
  bodyTemplate  String?
  config        Json?
  updatedAt     DateTime                @updatedAt
}

model NotificationDeliveryLog {
  id               String                     @id @default(uuid())
  notificationId   String?
  recipientUserId  String
  trigger          NotificationRuleTrigger
  title            String
  body             String
  status           NotificationDeliveryStatus @default(PENDING)
  dedupeKey        String?                    @unique
  sentAt           DateTime?
  readAt           DateTime?
  failureReason    String?
  metadata         Json?
  createdAt        DateTime                   @default(now())

  recipient User @relation("NotificationDeliveryRecipient", fields: [recipientUserId], references: [id])

  @@index([recipientUserId])
  @@index([trigger])
  @@index([status])
  @@index([createdAt])
}

model ReminderJobRun {
  id              String                @id @default(uuid())
  jobKey          String
  trigger         NotificationRuleTrigger
  status          ReminderJobStatus
  recipientCount  Int                   @default(0)
  failureMessage  String?
  lastRunAt       DateTime              @default(now())
  nextRunAt       DateTime?
  metadata        Json?

  @@index([jobKey])
  @@index([lastRunAt])
}

// --- Deployment-ready (DEPLOYMENT-READY-1) ---

model ChurchConfiguration {
  id                 String   @id @default("default")
  setupCompleted     Boolean  @default(false)
  setupStep          Int      @default(0)
  churchInfo         Json?
  leadership         Json?
  ministriesConfig   Json?
  choirsConfig       Json?
  protocolConfig     Json?
  servicesConfig     Json?
  serviceTimes       Json?
  choirRules         Json?
  protocolRules      Json?
  schedulingRules    Json?
  notificationRules  Json?
  attendanceRules    Json?
  demoModeEnabled    Boolean  @default(false)
  goLiveE2eVerified  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// --- Auth UX (AUTH-UX-1) ---

enum ChurchRelationshipType {
  EXISTING
  NEW_TO_CHURCH
  VISITOR
  RETURNING
}

model UxAnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

model PrayerRequest {
  id          String              @id @default(uuid())
  content     String
  isAnonymous Boolean             @default(true)
  displayName String?
  memberId    String?
  userId      String?
  ministryId  String
  status      PrayerRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  member   Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  user     User?    @relation("PrayerRequestSubmitter", fields: [userId], references: [id], onDelete: SetNull)

  @@index([ministryId, status])
  @@index([createdAt])
}

model ChurchWeeklyActivity {
  id          String   @id @default(uuid())
  title       String
  description String?
  dayOfWeek   Int
  startTime   String
  endTime     String?
  location    String?
  ministryId  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ministry Ministry? @relation(fields: [ministryId], references: [id], onDelete: SetNull)

  @@index([dayOfWeek, isActive])
  @@index([ministryId])
}

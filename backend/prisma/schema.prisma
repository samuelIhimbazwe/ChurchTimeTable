model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  isActive     Boolean    @default(true)
  fcmToken           String?
  refreshTokenHash   String?
  refreshTokenExpiresAt DateTime?
  preferredLanguage  String     @default("rw")
  createdAt          DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  member       Member?
  userRoles    UserRole[]
  auditLogs    AuditLog[]
  notifications Notification[]
  confirmedContributions ContributionRecord[] @relation("ContributionConfirmer")
  thankYouSentContributions ContributionRecord[] @relation("ContributionThankYouSender")
  announcementReads ChoirAnnouncementRead[]
  choirMemberships  ChoirMembership[]
  devotionsCreated  Devotion[]          @relation("DevotionAuthor")
  devotionBookmarks DevotionBookmark[]
  customRolesCreated ChoirCustomRole[]  @relation("CustomRoleAuthor")
  ministryLeadershipAssigned MinistryLeadershipAssignment[] @relation("MinistryLeadershipAssigner")
  ministryPermissionsGranted MinistryPermissionAssignment[] @relation("MinistryPermissionGranter")
  operationalUnitLeadershipAssigned OperationalUnitLeadershipAssignment[] @relation("OperationalUnitLeadershipAssigner")
  operationalUnitPermissionsGranted OperationalUnitPermissionAssignment[] @relation("OperationalUnitPermissionGranter")
  ministryAnnouncementsCreated      MinistryAnnouncement[]                @relation("MinistryAnnouncementAuthor")
  ministryDocumentsUploaded         MinistryDocument[]                    @relation("MinistryDocumentUploader")
  ministryDocumentVersionsUploaded  MinistryDocumentVersion[]             @relation("MinistryDocumentVersionUploader")
  ministryMeetingsCreated           MinistryMeeting[]                     @relation("MinistryMeetingCreator")
  ministryActivities                MinistryActivity[]                    @relation("MinistryActivityActor")
  assetsCreated                     Asset[]                               @relation("AssetCreator")
  assetActivities                   AssetActivity[]                       @relation("AssetActivityActor")
  ministryFundTransactions          MinistryFundTransaction[]             @relation("MinistryFundTransactionActor")
  ministryFundTransfersApproved     MinistryFundTransfer[]                @relation("MinistryFundTransferApprover")
  operationsCreated                 OperationOccurrence[]                 @relation("OperationCreator")
  operationsApproved                OperationOccurrence[]                 @relation("OperationApprover")
  operationNotifications            OperationNotification[]
  churchBroadcastsCreated           ChurchBroadcast[] @relation("BroadcastCreator")
  choirJoinRequestsReviewed         ChoirJoinRequest[] @relation("ChoirJoinReviewerUser")
  choirSponsorRequestsReviewed      ChoirSponsorRequest[] @relation("ChoirSponsorReviewerUser")
  importJobsUploaded                ImportJob[]
  uxAnalyticsEvents                 UxAnalyticsEvent[]
  notificationDeliveryLogs        NotificationDeliveryLog[] @relation("NotificationDeliveryRecipient")
  prayerRequestsSubmitted           PrayerRequest[]           @relation("PrayerRequestSubmitter")

  @@index([email])
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Member {
  id              String        @id @default(uuid())
  userId          String        @unique
  memberNumber    String?       @unique
  firstName       String
  lastName        String
  phone           String?
  ministry        MinistryScope @default(CHOIR)
  status              MemberStatus  @default(NEW_MEMBER)
  onboardingCompleted Boolean       @default(false)
  isChildrenChoir     Boolean       @default(false)
  serviceNumber   Int?
  clientUpdatedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  disciplineCases DisciplineCase[] @relation("DisciplineSubject")
  disciplineReported DisciplineCase[] @relation("DisciplineReporter")
  memberDues      MemberDues[]
  contributionRecords ContributionRecord[]
  choirCommitteeAssignments ChoirCommitteeMember[]
  protocolCommitteeAssignments ProtocolCommitteeMember[]
  protocolTeamMemberships ProtocolServiceTeamMember[]
  teamHeadAssignments ProtocolServiceTeam[] @relation("ProtocolTeamHead")
  familyMembership    FamilyMember?
  familiesHeaded      Family[]              @relation("FamilyHead")
  familyLeadershipHistory FamilyLeadershipHistory[]
  contributionAdjustments ContributionAdjustment[] @relation("ContributionAdjuster")
  familyApprovedContributions ContributionRecord[] @relation("ContributionFamilyApprover")
  familyRejectedContributions ContributionRecord[] @relation("ContributionFamilyRejecter")
  profile                   MemberProfile?
  statusHistory             MemberStatusHistory[]
  welfareCases              WelfareCase[]         @relation("WelfareSubject")
  welfareCasesCoordinated   WelfareCase[]         @relation("WelfareCoordinator")
  welfareContributions      WelfareContribution[]
  songUsageLed              SongUsageRecord[]
  songFavorites             SongFavorite[]
  rehearsalPlansLed         RehearsalPlan[]
  rehearsalAttendances      RehearsalAttendance[]
  meetingAttendance         MeetingAttendee[]
  meetingActionsOwned       MeetingActionItem[]
  uniformAssignments        UniformAssignment[]
  equipmentAssignments      EquipmentAssignment[]
  customRoleAssignments     ChoirMemberCustomRole[]
  ministryMemberships       MinistryMembership[]
  ministryLeadershipAssignments MinistryLeadershipAssignment[]
  ministryPermissionAssignments MinistryPermissionAssignment[]
  operationalUnitMemberships OperationalUnitMembership[]
  operationalUnitLeadershipAssignments OperationalUnitLeadershipAssignment[]
  operationalUnitPermissionAssignments OperationalUnitPermissionAssignment[]
  ministryAnnouncementReads            MinistryAnnouncementRead[]
  ministryMeetingAttendees             MinistryMeetingAttendee[]
  ministryMeetingActionItems           MinistryMeetingActionItem[] @relation("MinistryMeetingActionAssignee")
  assetCustodians                      AssetCustodian[]
  ministryExpensesRequested            MinistryExpense[] @relation("MinistryExpenseRequester")
  ministryExpensesApproved             MinistryExpense[] @relation("MinistryExpenseApprover")
  operationAssignments                 OperationAssignment[]
  protocolMemberProfile                ProtocolMemberProfile?
  protocolOccurrenceTeamMemberships    ProtocolOccurrenceTeamMember[]
  protocolReplacementRequestsAsOriginal ProtocolReplacementRequest[] @relation("ProtocolReplacementOriginal")
  protocolReplacementRequestsAsCover   ProtocolReplacementRequest[] @relation("ProtocolReplacementCover")
  protocolRankingEntries               ProtocolRankingEntry[]
  protocolCategoryRankingEntries     ProtocolCategoryRankingEntry[]
  protocolTeamLeader                   ProtocolTeamLeader?
  protocolTeamBackups                  ProtocolOccurrenceTeamBackup[]
  choirAttendances                     ChoirAttendance[]
  choirParticipationProfiles           ChoirMemberParticipationProfile[]
  choirCategoryRankingEntries          ChoirCategoryRankingEntry[]
  choirJoinRequests                    ChoirJoinRequest[]
  choirSponsorRequests                 ChoirSponsorRequest[]
  choirSponsorships                    ChoirSponsorship[]
  protocolInvitations                  ProtocolInvitation[]
  protocolMembershipClaims             ProtocolMembershipClaim[]
  protocolInvitationsSent              ProtocolInvitation[] @relation("ProtocolInviter")
  protocolClaimsReviewed               ProtocolMembershipClaim[] @relation("ProtocolClaimReviewer")
  prayerRequests                       PrayerRequest[]

  @@index([status])
  @@index([ministry])
  @@index([userId])
}

model ChoirCommitteeRole {
  id              String   @id @default(uuid())
  choirId         String
  name            String
  permissionsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  choir           Choir    @relation(fields: [choirId], references: [id], onDelete: Cascade)
  members         ChoirCommitteeMember[]

  @@unique([choirId, name])
  @@index([choirId])
}

model ChoirCommitteeMember {
  id          String   @id @default(uuid())
  choirId     String
  memberId    String
  roleId      String
  assignedAt  DateTime @default(now())
  assignedBy  String
  createdAt   DateTime @default(now())

  role        ChoirCommitteeRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  member      Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([choirId, memberId, roleId])
  @@index([choirId])
  @@index([memberId])
  @@index([roleId])
}

model ProtocolCommitteeRole {
  id              String   @id @default(uuid())
  ministryId      String
  name            String
  permissionsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  members         ProtocolCommitteeMember[]

  @@unique([ministryId, name])
  @@index([ministryId])
}

model ProtocolCommitteeMember {
  id          String   @id @default(uuid())
  ministryId  String
  memberId    String
  roleId      String
  assignedAt  DateTime @default(now())
  assignedBy  String
  createdAt   DateTime @default(now())

  role        ProtocolCommitteeRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  member      Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ministryId, memberId, roleId])
  @@index([ministryId])
  @@index([memberId])
  @@index([roleId])
}

model ProtocolServiceTeam {
  id           String   @id @default(uuid())
  month        Int
  year         Int
  serviceType  EventType
  teamHeadId   String
  status       ProtocolTeamStatus @default(DRAFT)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamHead     Member   @relation("ProtocolTeamHead", fields: [teamHeadId], references: [id], onDelete: Restrict)
  members      ProtocolServiceTeamMember[]

  @@unique([month, year, serviceType, teamHeadId])
  @@index([month, year])
  @@index([serviceType])
}

model ProtocolServiceTeamMember {
  id                String   @id @default(uuid())
  teamId            String
  memberId          String
  assignedByEngine  Boolean  @default(true)
  choirCompatible   Boolean  @default(false)
  overrideReason    String?
  createdAt         DateTime @default(now())

  team              ProtocolServiceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member            Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

model DisciplineCase {
  id          String          @id @default(uuid())
  memberId    String
  reporterId  String?
  ministry    MinistryScope
  stage       DisciplineStage @default(REPORTED)
  title       String
  description String
  resolution  String?
  actionTaken String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  closedAt    DateTime?
  member      Member          @relation("DisciplineSubject", fields: [memberId], references: [id])
  reporter    Member?         @relation("DisciplineReporter", fields: [reporterId], references: [id])

  @@index([memberId])
  @@index([stage])
  @@index([ministry])
}

model FinanceTransaction {
  id               String                 @id @default(uuid())
  ministryScope    MinistryScope          @default(CHOIR)
  type             TransactionType
  category         FinanceCategory
  amount           Decimal
  currency         String                 @default("RWF")
  description      String?
  memberId         String?
  recordedById     String
  approvedById     String?
  approvalStatus   FinanceApprovalStatus  @default(APPROVED)
  receiptUrl       String?
  relatedEventId   String?
  transactionDate  DateTime               @default(now())
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([ministryScope])
  @@index([type])
  @@index([transactionDate])
  @@index([memberId])
  @@index([relatedEventId])
  @@index([approvalStatus])
}

model Budget {
  id            String       @id @default(uuid())
  ministryScope MinistryScope @default(CHOIR)
  name          String
  kind          BudgetKind   @default(MONTHLY)
  amount        Decimal
  actualAmount  Decimal      @default(0)
  periodStart   DateTime
  periodEnd     DateTime
  relatedEventId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([ministryScope])
  @@index([periodStart, periodEnd])
  @@index([relatedEventId])
}

model MemberDues {
  id              String       @id @default(uuid())
  ministryScope   MinistryScope @default(CHOIR)
  memberId        String
  dueType         DueType      @default(MONTHLY_DUES)
  amount          Decimal
  amountDue       Decimal?
  amountPaid      Decimal      @default(0)
  period          String
  status          DueStatus    @default(UNPAID)
  paid            Boolean      @default(false)
  paidAt          DateTime?
  recordedById    String?
  approvedById    String?
  waivedReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  member          Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  contributionRecords ContributionRecord[]

  @@unique([memberId, period, ministryScope, dueType])
  @@index([memberId])
  @@index([ministryScope])
  @@index([status])
}

model ContributionTypeCatalog {
  id            String          @id @default(uuid())
  choirId       String?
  code          String
  name          String
  description   String?
  active        Boolean         @default(true)
  sortOrder     Int             @default(0)
  ministryScope MinistryScope   @default(CHOIR)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  choir         Choir?          @relation(fields: [choirId], references: [id])
  campaigns     ContributionCampaign[]
  records       ContributionRecord[]

  @@unique([choirId, code])
  @@index([choirId])
  @@index([active, ministryScope])
  @@index([sortOrder])
}

model ContributionCampaign {
  id                 String                     @id @default(uuid())
  choirId            String?
  contributionTypeId String
  name               String
  description        String?
  goalAmount         Decimal
  currency           String                     @default("RWF")
  status             ContributionCampaignStatus @default(DRAFT)
  periodStart        DateTime?
  periodEnd          DateTime?
  ministryScope      MinistryScope              @default(CHOIR)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  choir              Choir?                     @relation(fields: [choirId], references: [id])
  contributionType   ContributionTypeCatalog    @relation(fields: [contributionTypeId], references: [id], onDelete: Restrict)
  records            ContributionRecord[]

  @@index([choirId])
  @@index([contributionTypeId])
  @@index([status, ministryScope])
  @@index([periodStart, periodEnd])
}

model ContributionRecord {
  id                       String                   @id @default(uuid())
  memberId                 String
  familyId                 String?
  /// Set for sponsor gifts (no family) — routes treasurer inbox to the correct choir
  choirId                  String?
  financeTransactionId     String?
  memberDueId              String?
  /// @deprecated Sprint 10 — use contributionTypeCatalogId; kept for migration compat
  contributionType         ContributionType
  contributionTypeCatalogId String?
  contributionCampaignId   String?
  /// Member claim — immutable after submit
  claimedAmount            Decimal?
  /// Family-head confirmation — immutable after approve
  confirmedAmount          Decimal?
  discrepancyAmount        Decimal?
  discrepancyReason        String?
  /// Legacy amount field — mirrors claimedAmount during transition
  amount                   Decimal
  currency                 String                   @default("RWF")
  paymentAt                DateTime?
  paymentChannel           PaymentChannel?
  status                   ContributionStatus       @default(PENDING)
  referenceNumber          String                   @unique
  notes                    String?
  receiptUrl               String?
  familyApprovedAt         DateTime?
  familyApprovedByMemberId String?
  familyRejectedAt         DateTime?
  familyRejectedByMemberId String?
  rejectionReason          String?
  confirmedAt              DateTime?
  confirmedById            String?
  thankYouSentAt           DateTime?
  thankYouSentById         String?
  thankYouDeliveryStatus   ThankYouDeliveryStatus   @default(PENDING)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  member                   Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberDue                MemberDues?              @relation(fields: [memberDueId], references: [id])
  contributionTypeCatalog  ContributionTypeCatalog? @relation(fields: [contributionTypeCatalogId], references: [id])
  contributionCampaign     ContributionCampaign?    @relation(fields: [contributionCampaignId], references: [id])
  confirmedBy              User?                    @relation("ContributionConfirmer", fields: [confirmedById], references: [id])
  thankYouSentBy           User?                    @relation("ContributionThankYouSender", fields: [thankYouSentById], references: [id])
  familyApprovedBy         Member?                  @relation("ContributionFamilyApprover", fields: [familyApprovedByMemberId], references: [id])
  familyRejectedBy         Member?                  @relation("ContributionFamilyRejecter", fields: [familyRejectedByMemberId], references: [id])
  choir                    Choir?                   @relation(fields: [choirId], references: [id])
  adjustments              ContributionAdjustment[]

  @@index([memberId])
  @@index([choirId])
  @@index([status])
  @@index([contributionType])
  @@index([contributionTypeCatalogId])
  @@index([contributionCampaignId])
  @@index([financeTransactionId])
  @@index([memberDueId])
  @@index([confirmedAt])
  @@index([familyId])
  @@index([familyApprovedAt])
  @@index([paymentAt])
}

model ContributionAdjustment {
  id                     String                         @id @default(uuid())
  contributionRecordId   String
  /// Signed delta applied to confirmedAmount (e.g. +3000, -2000)
  adjustmentAmount       Decimal
  category               ContributionAdjustmentCategory
  reason                 String
  adjustedByMemberId     String
  referenceContributionId String?
  createdAt              DateTime                       @default(now())
  contributionRecord   ContributionRecord @relation(fields: [contributionRecordId], references: [id], onDelete: Cascade)
  adjustedBy           Member             @relation("ContributionAdjuster", fields: [adjustedByMemberId], references: [id])

  @@index([contributionRecordId])
  @@index([adjustedByMemberId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SyncConflict {
  id           String   @id @default(uuid())
  userId       String
  entity       String
  entityId     String?
  clientPayload Json
  serverPayload Json?
  reason       String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  choirId    String?
  ministryId String?
  type       NotificationType
  title      String
  body       String
  data       Json?
  read       Boolean          @default(false)
  archived   Boolean          @default(false)
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  choir      Choir?           @relation(fields: [choirId], references: [id])
  ministry   Ministry?        @relation(fields: [ministryId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, archived])
  @@index([userId, choirId])
  @@index([userId, ministryId])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// --- Multi-choir foundation ---

enum ChoirKind {
  PRIMARY
  SPECIAL
  CHILDREN
}

model Choir {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  choirKind   ChoirKind @default(PRIMARY)
  leaderDisplayName String?
  isPublicJoinable Boolean @default(true)
  isActive    Boolean  @default(true)
  showMemberCountPublic Boolean @default(false)
  publicProfileJson     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships           ChoirMembership[]
  joinRequests          ChoirJoinRequest[]
  sponsorRequests       ChoirSponsorRequest[]
  sponsorships          ChoirSponsorship[]
  devotions             Devotion[]
  customRoles           ChoirCustomRole[]
  families              Family[]
  welfareCases          WelfareCase[]
  songs                 Song[]
  songCategories        SongCategory[]
  documents             ChoirDocument[]
  meetings              ChoirMeeting[]
  announcements         ChoirAnnouncement[]
  uniformTypes          UniformType[]
  equipmentAssets       EquipmentAsset[]
  contributionTypes     ContributionTypeCatalog[]
  contributionCampaigns ContributionCampaign[]
  sponsorContributions  ContributionRecord[]
  committeeRoles        ChoirCommitteeRole[]
  notifications         Notification[]
  protocolTeamLeaders   ProtocolTeamLeader[]
  activities            ChoirActivity[]
  serviceAssignments    ChoirServiceAssignment[]
  serviceEligibility    ChoirServiceEligibility?
  participationProfiles ChoirMemberParticipationProfile[]
  servicePreparationPlans ServicePreparationPlan[]
  churchServiceRequestsPreferred ChurchServiceRequest[] @relation("ChurchServiceRequestPreferred")
  churchServiceRequestsAssigned  ChurchServiceRequest[] @relation("ChurchServiceRequestAssigned")
  dissolutionTransfersSource ChoirDissolutionTransfer[] @relation("DissolutionSource")
  dissolutionTransfersTarget ChoirDissolutionTransfer[] @relation("DissolutionTarget")

  @@index([isActive])
}

model ChoirMembership {
  id       String   @id @default(uuid())
  userId   String
  choirId  String
  role     String
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  choir    Choir    @relation(fields: [choirId], references: [id], onDelete: Cascade)

  @@unique([userId, choirId])
  @@index([choirId])
  @@index([userId])
  @@index([isActive])
}

model Devotion {
  id                  String                 @id @default(uuid())
  choirId             String?
  ministryId          String?
  operationalUnitId   String?
  visibilityScope     DevotionVisibilityScope @default(CHOIR)
  title               String
  content             String
  verseReference      String?
  verseText           String?
  type                DevotionType
  prayerDate          DateTime?
  isPinned            Boolean                @default(false)
  publishedAt         DateTime?
  expiresAt           DateTime?
  createdById         String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  choir               Choir?                 @relation(fields: [choirId], references: [id], onDelete: Cascade)
  ministry            Ministry?              @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  operationalUnit     OperationalUnit?       @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  createdBy           User                   @relation("DevotionAuthor", fields: [createdById], references: [id])
  bookmarks           DevotionBookmark[]

  @@index([choirId, isPinned])
  @@index([choirId, type])
  @@index([choirId, publishedAt])
  @@index([ministryId, publishedAt])
  @@index([operationalUnitId])
  @@index([visibilityScope])
}

model DevotionBookmark {
  id         String   @id @default(uuid())
  userId     String
  devotionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  devotion   Devotion @relation(fields: [devotionId], references: [id], onDelete: Cascade)

  @@unique([userId, devotionId])
  @@index([userId])
}

model ChoirCustomRole {
  id           String   @id @default(uuid())
  choirId      String
  name         String
  description  String?
  isSystemRole Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  choir        Choir    @relation(fields: [choirId], references: [id], onDelete: Cascade)
  createdBy    User     @relation("CustomRoleAuthor", fields: [createdById], references: [id])
  permissions  ChoirCustomRolePermission[]
  assignments  ChoirMemberCustomRole[]

  @@unique([choirId, name])
  @@index([choirId, isActive])
}

model ChoirCustomRolePermission {
  roleId     String
  permission String
  role       ChoirCustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@index([roleId])
}

model ChoirMemberCustomRole {
  id           String   @id @default(uuid())
  memberId     String
  choirId      String
  customRoleId String
  assignedById String
  assignedAt   DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  customRole   ChoirCustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([memberId, choirId, customRoleId])
  @@index([choirId])
  @@index([memberId])
  @@index([customRoleId])
}

model Family {
  id                 String                    @id @default(uuid())
  choirId            String?
  familyCode         String
  familyName         String
  headMemberId       String?
  delegationEnabled  Boolean                   @default(false)
  notes              String?
  /// MoMo / bank details shown to members when paying family contributions
  paymentMomoNumber      String?
  paymentMomoAccountName String?
  paymentBankAccount     String?
  paymentBankName        String?
  paymentInstructions    String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  choir              Choir?                    @relation(fields: [choirId], references: [id])
  headMember         Member?                   @relation("FamilyHead", fields: [headMemberId], references: [id])
  members            FamilyMember[]
  leadershipHistory  FamilyLeadershipHistory[]

  @@unique([choirId, familyCode])
  @@index([choirId])
  @@index([headMemberId])
}

model FamilyMember {
  id        String           @id @default(uuid())
  familyId  String
  memberId  String           @unique
  role      FamilyMemberRole @default(MEMBER)
  joinedAt  DateTime         @default(now())
  createdAt DateTime         @default(now())
  family    Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member    Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([memberId])
  @@index([role])
}

model FamilyLeadershipHistory {
  id              String           @id @default(uuid())
  familyId        String
  memberId        String
  role            FamilyMemberRole
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  assignedByUserId String?
  createdAt       DateTime         @default(now())
  family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member          Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([memberId])
  @@index([role])
  @@index([startedAt])
  @@index([endedAt])
}

model FamilyCodeSequence {
  id        String   @id @default("primary")
  nextValue Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberNumberSequence {
  id        String   @id @default(cuid())
  nextValue Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Choir MVP: member lifecycle ---

model MemberProfile {
  id                    String    @id @default(uuid())
  memberId              String    @unique
  gender                MemberGender @default(UNSPECIFIED)
  voicePart             ChoirVoicePart @default(UNSPECIFIED)
  dateOfBirth           DateTime?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  baptismDate           DateTime?
  choirJoinDate         DateTime?
  notes                 String?
  skillsJson            Json?
  instrumentsJson       Json?
  availabilityJson      Json?
  churchRelationship    ChurchRelationshipType?
  signupInterests       Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  member                Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model MemberStatusHistory {
  id         String       @id @default(uuid())
  memberId   String
  fromStatus MemberStatus?
  toStatus   MemberStatus
  reason     String?
  changedByUserId String?
  createdAt  DateTime     @default(now())
  member     Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([createdAt])
}

// --- Choir MVP: welfare ---

model WelfareCategory {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cases       WelfareCase[]
}

model WelfareCase {
  id              String            @id @default(uuid())
  choirId         String?
  memberId        String
  familyId        String?
  categoryId      String
  title           String
  description     String
  urgency         WelfareUrgency    @default(NORMAL)
  status          WelfareCaseStatus @default(OPEN)
  coordinatorId   String?
  supportPlan     String?
  requestedAmount Decimal?
  approvedAmount  Decimal?
  targetDate      DateTime?
  documentUrls    Json?
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  choir           Choir?            @relation(fields: [choirId], references: [id])
  member          Member            @relation("WelfareSubject", fields: [memberId], references: [id])
  coordinator     Member?           @relation("WelfareCoordinator", fields: [coordinatorId], references: [id])
  category        WelfareCategory   @relation(fields: [categoryId], references: [id])
  contributions   WelfareContribution[]
  assistance      WelfareAssistance[]

  @@index([choirId])
  @@index([memberId])
  @@index([familyId])
  @@index([status])
  @@index([categoryId])
}

model WelfareContribution {
  id            String   @id @default(uuid())
  caseId        String?
  contributorId String
  amount        Decimal
  currency      String   @default("RWF")
  paymentChannel String?
  paymentAt     DateTime @default(now())
  notes         String?
  isAnonymous   Boolean  @default(false)
  receiptUrl    String?
  recordedByUserId String?
  createdAt     DateTime @default(now())
  case          WelfareCase? @relation(fields: [caseId], references: [id])
  contributor   Member   @relation(fields: [contributorId], references: [id])

  @@index([caseId])
  @@index([contributorId])
  @@index([paymentAt])
}

model WelfareAssistance {
  id            String                @id @default(uuid())
  caseId        String
  assistanceType WelfareAssistanceType
  description   String
  amount        Decimal?
  currency      String?               @default("RWF")
  deliveredAt   DateTime              @default(now())
  recordedByUserId String?
  createdAt     DateTime              @default(now())
  case          WelfareCase           @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([deliveredAt])
}

// --- Choir MVP: music library ---

model SongCategory {
  id        String   @id @default(uuid())
  choirId   String?
  code      String
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  choir     Choir?   @relation(fields: [choirId], references: [id])
  songs     Song[]

  @@unique([choirId, code])
  @@index([choirId])
}

model Song {
  id                 String   @id @default(uuid())
  choirId            String?
  title              String
  alternateTitle     String?
  language           String?
  lyricist           String?
  composer           String?
  arranger           String?
  conductedBy        String?
  producedBy         String?
  performedBy        String?
  genre              String?
  voiceParts         String?
  durationSeconds    Int?
  releaseDate        DateTime?
  year               Int?
  shortSummary       String?
  fullDescription    String?
  recordingStudio    String?
  mixingEngineer     String?
  masteringBy        String?
  recordingType      String?
  listenLinksJson    Json?
  copyrightInfo      String?
  source             String?
  scriptureReference String?
  lyricsText         String?
  notes              String?
  categoryId         String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  choir              Choir?   @relation(fields: [choirId], references: [id])
  category           SongCategory? @relation(fields: [categoryId], references: [id])
  assets             SongAsset[]
  usageRecords       SongUsageRecord[]
  rehearsalPlanSongs RehearsalPlanSong[]
  favorites          SongFavorite[]
  servicePreparationItems ServicePreparationItem[]

  @@index([title])
  @@index([categoryId])
  @@index([choirId])
}

model SongFavorite {
  id        String   @id @default(uuid())
  memberId  String
  songId    String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([memberId, songId])
  @@index([memberId])
}

model SongAsset {
  id        String        @id @default(uuid())
  songId    String
  assetType SongAssetType
  fileName  String
  fileUrl   String
  mimeType  String?
  fileSize  Int?
  createdAt DateTime      @default(now())
  song      Song          @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
}

model SongUsageRecord {
  id        String   @id @default(uuid())
  songId    String
  rehearsalPlanId String?
  leaderId  String?
  usedAt    DateTime @default(now())
  notes     String?
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  leader    Member?  @relation(fields: [leaderId], references: [id])

  @@index([songId])
  @@index([usedAt])
}

// --- Choir MVP: rehearsal operations ---

model VoiceSection {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  planSections RehearsalPlanSection[]
}

model RehearsalPlan {
  id              String   @id @default(uuid())
  choirActivityId String   @unique
  leaderId        String?
  objectives      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  choirActivity   ChoirActivity @relation(fields: [choirActivityId], references: [id], onDelete: Cascade)
  leader          Member?  @relation(fields: [leaderId], references: [id])
  songs           RehearsalPlanSong[]
  sections        RehearsalPlanSection[]

  @@index([leaderId])
}

model RehearsalPlanSong {
  id               String @id @default(uuid())
  rehearsalPlanId  String
  songId           String
  sortOrder        Int    @default(0)
  estimatedMinutes Int?
  difficulty       String?
  priority         Int    @default(0)
  readinessPercent Int?
  notes            String?
  plan             RehearsalPlan @relation(fields: [rehearsalPlanId], references: [id], onDelete: Cascade)
  song             Song          @relation(fields: [songId], references: [id])

  @@unique([rehearsalPlanId, songId])
}

model RehearsalPlanSection {
  id               String @id @default(uuid())
  rehearsalPlanId  String
  voiceSectionId   String
  focusNotes       String?
  readinessStatus  RehearsalReadinessStatus @default(NOT_STARTED)
  readinessPercent Int?
  plan             RehearsalPlan @relation(fields: [rehearsalPlanId], references: [id], onDelete: Cascade)
  voiceSection     VoiceSection  @relation(fields: [voiceSectionId], references: [id])

  @@unique([rehearsalPlanId, voiceSectionId])
}

model RehearsalAttendance {
  id               String                   @id @default(uuid())
  choirActivityId  String
  memberId         String
  status           RehearsalAttendanceStatus
  notes            String?
  recordedByUserId String?
  recordedAt       DateTime                 @default(now())
  choirActivity    ChoirActivity            @relation(fields: [choirActivityId], references: [id], onDelete: Cascade)
  member           Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([choirActivityId, memberId])
  @@index([choirActivityId])
  @@index([memberId])
}

// --- Choir MVP: communication ---

model ChoirAnnouncement {
  id          String               @id @default(uuid())
  choirId     String?
  title       String
  body        String
  audience    AnnouncementAudience @default(ENTIRE_CHOIR)
  audienceRef String?
  publishedAt DateTime?
  expiresAt   DateTime?
  createdByUserId String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  choir       Choir?               @relation(fields: [choirId], references: [id])
  reads       ChoirAnnouncementRead[]

  @@index([choirId])
  @@index([publishedAt])
  @@index([audience])
}

model ChoirAnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())
  acknowledged   Boolean  @default(false)
  announcement   ChoirAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

// --- Choir MVP: documents ---

model ChoirDocument {
  id          String                @id @default(uuid())
  choirId     String?
  title       String
  category    ChoirDocumentCategory @default(OTHER)
  description String?
  currentVersionId String?          @unique
  createdByUserId String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  choir       Choir?                @relation(fields: [choirId], references: [id])
  versions    ChoirDocumentVersion[]
  currentVersion ChoirDocumentVersion? @relation("CurrentDocumentVersion", fields: [currentVersionId], references: [id])

  @@index([choirId])
}

model ChoirDocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  versionNumber Int
  fileName    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  changeNotes String?
  uploadedByUserId String
  createdAt   DateTime @default(now())
  document    ChoirDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  currentFor  ChoirDocument? @relation("CurrentDocumentVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

// --- Choir MVP: meetings ---

model ChoirMeeting {
  id          String        @id @default(uuid())
  choirId     String?
  title       String
  scheduledAt DateTime
  location    String?
  agenda      String?
  minutes     String?
  status      MeetingStatus @default(SCHEDULED)
  createdByUserId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  choir       Choir?        @relation(fields: [choirId], references: [id])
  attendees   MeetingAttendee[]
  decisions   MeetingDecision[]
  actionItems MeetingActionItem[]

  @@index([choirId])
}

model MeetingAttendee {
  id        String @id @default(uuid())
  meetingId String
  memberId  String
  present   Boolean @default(false)
  meeting   ChoirMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  member    Member       @relation(fields: [memberId], references: [id])

  @@unique([meetingId, memberId])
}

model MeetingDecision {
  id        String   @id @default(uuid())
  meetingId String
  decision  String
  createdAt DateTime @default(now())
  meeting   ChoirMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model MeetingActionItem {
  id        String           @id @default(uuid())
  meetingId String
  title     String
  ownerId   String?
  dueAt     DateTime?
  status    ActionItemStatus @default(OPEN)
  meeting   ChoirMeeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  owner     Member?          @relation(fields: [ownerId], references: [id])

  @@index([meetingId])
  @@index([status])
}

// --- Choir MVP: uniforms ---

model UniformType {
  id          String @id @default(uuid())
  choirId     String?
  code        String
  name        String
  description String?
  choir       Choir? @relation(fields: [choirId], references: [id])
  items       UniformItem[]

  @@unique([choirId, code])
  @@index([choirId])
}

model UniformItem {
  id           String            @id @default(uuid())
  uniformTypeId String
  label        String
  size         String?
  status       UniformItemStatus @default(AVAILABLE)
  condition    String?
  assignments  UniformAssignment[]
  uniformType  UniformType       @relation(fields: [uniformTypeId], references: [id])

  @@index([uniformTypeId])
  @@index([status])
}

model UniformAssignment {
  id           String   @id @default(uuid())
  uniformItemId String
  memberId     String
  issuedAt     DateTime @default(now())
  returnedAt   DateTime?
  notes        String?
  item         UniformItem @relation(fields: [uniformItemId], references: [id])
  member       Member      @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([uniformItemId])
}

// --- Choir MVP: equipment ---

model EquipmentAsset {
  id           String             @id @default(uuid())
  choirId      String?
  name         String
  category     String?
  serialNumber String?            @unique
  condition    EquipmentCondition @default(GOOD)
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  choir        Choir?             @relation(fields: [choirId], references: [id])
  assignments  EquipmentAssignment[]
  maintenance  EquipmentMaintenanceLog[]

  @@index([choirId])
}

model EquipmentAssignment {
  id          String                    @id @default(uuid())
  equipmentId String
  memberId    String?
  status      EquipmentAssignmentStatus @default(ASSIGNED)
  assignedAt  DateTime                  @default(now())
  returnedAt  DateTime?
  notes       String?
  equipment   EquipmentAsset            @relation(fields: [equipmentId], references: [id])
  member      Member?                   @relation(fields: [memberId], references: [id])

  @@index([equipmentId])
  @@index([memberId])
}

model EquipmentMaintenanceLog {
  id          String   @id @default(uuid())
  equipmentId String
  description String
  cost        Decimal?
  performedAt DateTime @default(now())
  equipment   EquipmentAsset @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

// --- Ministry Foundation (MF-1) ---

model Ministry {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships            MinistryMembership[]
  leadershipPositions    MinistryLeadershipPosition[]
  leadershipAssignments  MinistryLeadershipAssignment[]
  permissionAssignments  MinistryPermissionAssignment[]
  settings               MinistrySettings?
  operationalUnits       OperationalUnit[]
  announcements          MinistryAnnouncement[]
  documents              MinistryDocument[]
  meetings               MinistryMeeting[]
  activities             MinistryActivity[]
  devotions              Devotion[]
  notifications          Notification[]
  funds                  MinistryFund[]
  budgets                MinistryBudget[]
  expenses               MinistryExpense[]
  prayerRequests         PrayerRequest[]
  weeklyActivities       ChurchWeeklyActivity[]

  @@index([isActive])
}

model MinistryMembership {
  id         String                   @id @default(uuid())
  ministryId String
  memberId   String
  joinedAt   DateTime                 @default(now())
  status     MinistryMembershipStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ministryId, memberId])
  @@index([memberId])
  @@index([ministryId, status])
}

model MinistryLeadershipPosition {
  id          String   @id @default(uuid())
  ministryId  String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ministry    Ministry                       @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  assignments MinistryLeadershipAssignment[]

  @@unique([ministryId, name])
  @@index([ministryId, isActive])
}

model MinistryLeadershipAssignment {
  id               String    @id @default(uuid())
  ministryId       String
  memberId         String
  positionId       String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  assignedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ministry   Ministry                   @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  member     Member                     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  position   MinistryLeadershipPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  assignedBy User?                      @relation("MinistryLeadershipAssigner", fields: [assignedByUserId], references: [id])

  @@index([ministryId, endedAt])
  @@index([memberId])
  @@index([positionId])
}

model MinistryPermissionAssignment {
  id              String    @id @default(uuid())
  ministryId      String
  memberId        String
  permission      String
  grantedByUserId String?
  grantedAt       DateTime  @default(now())
  revokedAt       DateTime?

  ministry  Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  grantedBy User?    @relation("MinistryPermissionGranter", fields: [grantedByUserId], references: [id])

  @@index([ministryId, memberId])
  @@index([ministryId, permission])
  @@index([memberId, revokedAt])
}

model MinistrySettings {
  ministryId            String   @id
  allowDevotions          Boolean  @default(true)
  allowAnnouncements      Boolean  @default(true)
  allowDocuments          Boolean  @default(true)
  allowMeetings           Boolean  @default(true)
  allowAssets             Boolean  @default(true)
  allowFinance            Boolean  @default(true)
  allowOperationalUnits   Boolean  @default(false)
  allowReporting          Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
}

// --- Operational Units Foundation (MF-2) ---

model OperationalUnit {
  id          String              @id @default(uuid())
  ministryId  String
  code        String
  name        String
  description String?
  type        OperationalUnitType @default(CUSTOM)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  ministry              Ministry                              @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  memberships           OperationalUnitMembership[]
  leadershipPositions   OperationalUnitLeadershipPosition[]
  leadershipAssignments OperationalUnitLeadershipAssignment[]
  permissionAssignments OperationalUnitPermissionAssignment[]
  settings              OperationalUnitSettings?
  devotions               Devotion[]
  operationAssignments    OperationAssignment[]
  protocolMemberProfiles  ProtocolMemberProfile[]

  @@unique([ministryId, code])
  @@unique([ministryId, name])
  @@index([ministryId, isActive])
  @@index([type])
}

model OperationalUnitMembership {
  id                String                   @id @default(uuid())
  operationalUnitId String
  memberId          String
  status            MinistryMembershipStatus @default(ACTIVE)
  joinedAt          DateTime                 @default(now())
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  operationalUnit OperationalUnit @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  member          Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([operationalUnitId, memberId])
  @@index([memberId])
  @@index([operationalUnitId, status])
}

model OperationalUnitLeadershipPosition {
  id                String   @id @default(uuid())
  operationalUnitId String
  name              String
  description       String?
  isSystem          Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  operationalUnit OperationalUnit                   @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  assignments     OperationalUnitLeadershipAssignment[]

  @@unique([operationalUnitId, name])
  @@index([operationalUnitId, isActive])
}

model OperationalUnitLeadershipAssignment {
  id                String    @id @default(uuid())
  operationalUnitId String
  memberId          String
  positionId        String
  startedAt         DateTime  @default(now())
  endedAt           DateTime?
  assignedByUserId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  operationalUnit OperationalUnit                   @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  member          Member                            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  position        OperationalUnitLeadershipPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  assignedBy      User?                             @relation("OperationalUnitLeadershipAssigner", fields: [assignedByUserId], references: [id])

  @@index([operationalUnitId, endedAt])
  @@index([memberId])
  @@index([positionId])
}

model OperationalUnitPermissionAssignment {
  id                String    @id @default(uuid())
  operationalUnitId String
  memberId          String
  permission        String
  grantedByUserId   String?
  grantedAt         DateTime  @default(now())
  revokedAt         DateTime?

  operationalUnit OperationalUnit @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  member          Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  grantedBy       User?           @relation("OperationalUnitPermissionGranter", fields: [grantedByUserId], references: [id])

  @@index([operationalUnitId, memberId])
  @@index([operationalUnitId, permission])
  @@index([memberId, revokedAt])
}

model OperationalUnitSettings {
  operationalUnitId   String   @id
  allowEvents         Boolean  @default(true)
  allowAttendance     Boolean  @default(true)
  allowReports        Boolean  @default(true)
  allowAnnouncements  Boolean  @default(true)
  allowDocuments      Boolean  @default(true)
  allowAssets         Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  operationalUnit OperationalUnit @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
}

// --- Ministry Services Platform (MF-3) ---

model MinistryAnnouncement {
  id              String                     @id @default(uuid())
  ministryId      String
  title           String
  content         String
  priority        MinistryAnnouncementPriority @default(NORMAL)
  audienceType    MinistryAnnouncementAudience @default(ALL_MINISTRY)
  audienceRef     String?
  publishedAt     DateTime?
  expiresAt       DateTime?
  createdByUserId String
  isPinned        Boolean                    @default(false)
  isActive        Boolean                    @default(true)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  ministry  Ministry                   @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy User                       @relation("MinistryAnnouncementAuthor", fields: [createdByUserId], references: [id])
  reads     MinistryAnnouncementRead[]

  @@index([ministryId, isActive])
  @@index([ministryId, isPinned])
  @@index([ministryId, publishedAt])
}

model MinistryAnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  memberId       String
  readAt         DateTime @default(now())

  announcement MinistryAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  member       Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([announcementId, memberId])
  @@index([memberId])
}

model MinistryDocument {
  id               String                 @id @default(uuid())
  ministryId       String
  title            String
  description      String?
  category         MinistryDocumentCategory @default(OTHER)
  currentVersionId String?                @unique
  isArchived       Boolean                @default(false)
  uploadedByUserId String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  ministry       Ministry                  @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  uploadedBy     User                      @relation("MinistryDocumentUploader", fields: [uploadedByUserId], references: [id])
  versions       MinistryDocumentVersion[]
  currentVersion MinistryDocumentVersion?  @relation("MinistryDocumentCurrentVersion", fields: [currentVersionId], references: [id])

  @@index([ministryId, isArchived])
  @@index([ministryId, category])
}

model MinistryDocumentVersion {
  id               String   @id @default(uuid())
  documentId       String
  versionNumber    Int
  fileName         String
  fileUrl          String
  mimeType         String?
  fileSize         Int?
  changeNotes      String?
  uploadedByUserId String
  createdAt        DateTime @default(now())

  document   MinistryDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation("MinistryDocumentVersionUploader", fields: [uploadedByUserId], references: [id])
  currentFor MinistryDocument? @relation("MinistryDocumentCurrentVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model MinistryMeeting {
  id              String        @id @default(uuid())
  ministryId      String
  title           String
  description     String?
  scheduledAt     DateTime
  location        String?
  status          MeetingStatus @default(SCHEDULED)
  createdByUserId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  ministry    Ministry                  @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  createdBy   User                      @relation("MinistryMeetingCreator", fields: [createdByUserId], references: [id])
  attendees   MinistryMeetingAttendee[]
  decisions   MinistryMeetingDecision[]
  actionItems MinistryMeetingActionItem[]

  @@index([ministryId, status])
  @@index([ministryId, scheduledAt])
}

model MinistryMeetingAttendee {
  id        String  @id @default(uuid())
  meetingId String
  memberId  String
  present   Boolean @default(false)

  meeting MinistryMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  member  Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([meetingId, memberId])
}

model MinistryMeetingDecision {
  id        String   @id @default(uuid())
  meetingId String
  summary   String
  createdAt DateTime @default(now())

  meeting MinistryMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model MinistryMeetingActionItem {
  id         String           @id @default(uuid())
  meetingId  String
  title      String
  assigneeId String?
  dueDate    DateTime?
  status     ActionItemStatus @default(OPEN)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  meeting  MinistryMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee Member?         @relation("MinistryMeetingActionAssignee", fields: [assigneeId], references: [id])

  @@index([meetingId, status])
  @@index([assigneeId])
}

model MinistryActivity {
  id         String               @id @default(uuid())
  ministryId String
  type       MinistryActivityType
  actorUserId String?
  actorLabel String?
  entityType String?
  entityId   String?
  summary    String?
  metadata   Json?
  createdAt  DateTime             @default(now())

  ministry Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  actor    User?    @relation("MinistryActivityActor", fields: [actorUserId], references: [id])

  @@index([ministryId, createdAt])
  @@index([ministryId, type])
  @@index([actorUserId])
}

// --- Resource & Asset Management Foundation (MF-4) ---

model AssetCategory {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]

  @@index([isSystem])
}

model Asset {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  description     String?
  categoryId      String
  status          AssetStatus     @default(ACTIVE)
  condition       AssetCondition  @default(GOOD)
  purchaseDate    DateTime?
  purchaseValue   Decimal?
  serialNumber    String?
  manufacturer    String?
  model           String?
  imageUrls       Json?
  notes           String?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  category      AssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy     User?               @relation("AssetCreator", fields: [createdByUserId], references: [id])
  ownerships    AssetOwnership[]
  custodians    AssetCustodian[]
  assignments   AssetAssignment[]
  maintenance   AssetMaintenance[]
  activities    AssetActivity[]
  uniformProfile   UniformProfile?
  instrumentProfile InstrumentProfile?

  @@index([categoryId])
  @@index([status])
  @@index([condition])
}

model AssetOwnership {
  id                  String         @id @default(uuid())
  assetId             String
  ownerType           AssetOwnerType
  ownerId             String
  ownershipPercentage Decimal?
  contributedAmount   Decimal?
  notes               String?
  createdAt           DateTime       @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, ownerType, ownerId])
  @@index([ownerType, ownerId])
  @@index([assetId])
}

model AssetCustodian {
  id         String    @id @default(uuid())
  assetId    String
  memberId   String
  assignedAt DateTime  @default(now())
  releasedAt DateTime?
  notes      String?

  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([assetId, releasedAt])
  @@index([memberId])
}

model AssetAssignment {
  id               String                    @id @default(uuid())
  assetId          String
  assignedToType   AssetAssignmentTargetType
  assignedToId     String
  purpose          String?
  assignedAt       DateTime                  @default(now())
  expectedReturnAt DateTime?
  returnedAt       DateTime?
  notes            String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, returnedAt])
  @@index([assignedToType, assignedToId])
}

model AssetMaintenance {
  id                   String               @id @default(uuid())
  assetId              String
  type                 AssetMaintenanceType
  description          String
  cost                 Decimal?
  vendor               String?
  performedBy          String?
  performedAt          DateTime             @default(now())
  nextMaintenanceDate  DateTime?
  attachments          Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, performedAt])
  @@index([nextMaintenanceDate])
}

model AssetActivity {
  id           String            @id @default(uuid())
  assetId      String
  activityType AssetActivityType
  actorId      String?
  metadata     Json?
  createdAt    DateTime          @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actor User? @relation("AssetActivityActor", fields: [actorId], references: [id])

  @@index([assetId, createdAt])
  @@index([activityType])
}

model UniformProfile {
  assetId String           @id
  size    String?
  gender  MemberGender?
  style   String?
  color   String?
  status  UniformAssetStatus @default(AVAILABLE)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model InstrumentProfile {
  assetId              String  @id
  instrumentType       String
  tuningNotes          String?
  maintenanceIntervalDays Int?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([instrumentType])
}

// --- Ministry Finance & Resource Funds (MF-5) ---

model MinistryFund {
  id          String           @id @default(uuid())
  ministryId  String
  name        String
  description String?
  type        MinistryFundType @default(GENERAL)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  ministry     Ministry                  @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  transactions MinistryFundTransaction[]
  expenses     MinistryExpense[]
  transfersOut MinistryFundTransfer[]    @relation("FundTransferFrom")
  transfersIn  MinistryFundTransfer[]      @relation("FundTransferTo")

  @@unique([ministryId, name])
  @@index([ministryId, isActive])
  @@index([type])
}

model MinistryBudget {
  id          String               @id @default(uuid())
  ministryId  String
  name        String
  fiscalYear  Int
  totalBudget Decimal
  notes       String?
  status      MinistryBudgetStatus @default(DRAFT)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  ministry   Ministry                 @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  categories MinistryBudgetCategory[]
  expenses   MinistryExpense[]

  @@unique([ministryId, name, fiscalYear])
  @@index([ministryId, status])
  @@index([fiscalYear])
}

model MinistryBudgetCategory {
  id              String   @id @default(uuid())
  budgetId        String
  name            String
  allocatedAmount Decimal
  spentAmount     Decimal  @default(0)
  remainingAmount Decimal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget   MinistryBudget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expenses MinistryExpense[]

  @@unique([budgetId, name])
  @@index([budgetId])
}

model MinistryExpense {
  id            String                @id @default(uuid())
  ministryId    String
  fundId        String
  categoryId    String?
  budgetId      String?
  amount        Decimal
  description   String
  receiptUrls   Json?
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  expenseDate   DateTime              @default(now())
  status        MinistryExpenseStatus @default(DRAFT)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  ministry    Ministry                @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  fund        MinistryFund            @relation(fields: [fundId], references: [id], onDelete: Restrict)
  category    MinistryBudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  budget      MinistryBudget?         @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  requestedBy Member                  @relation("MinistryExpenseRequester", fields: [requestedById], references: [id])
  approvedBy  Member?                 @relation("MinistryExpenseApprover", fields: [approvedById], references: [id])

  @@index([ministryId, status])
  @@index([fundId])
  @@index([expenseDate])
}

model MinistryFundTransaction {
  id          String                      @id @default(uuid())
  fundId      String
  type        MinistryFundTransactionType
  amount      Decimal
  description String?
  actorId     String?
  transferId  String?
  expenseId   String?
  createdAt   DateTime                    @default(now())

  fund     MinistryFund          @relation(fields: [fundId], references: [id], onDelete: Cascade)
  actor    User?                   @relation("MinistryFundTransactionActor", fields: [actorId], references: [id])
  transfer MinistryFundTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([fundId, createdAt])
  @@index([type])
}

model MinistryFundTransfer {
  id           String   @id @default(uuid())
  fromFundId   String
  toFundId     String
  amount       Decimal
  reason       String?
  approvedById String?
  createdAt    DateTime @default(now())

  fromFund     MinistryFund              @relation("FundTransferFrom", fields: [fromFundId], references: [id], onDelete: Restrict)
  toFund       MinistryFund              @relation("FundTransferTo", fields: [toFundId], references: [id], onDelete: Restrict)
  approvedBy   User?                     @relation("MinistryFundTransferApprover", fields: [approvedById], references: [id])
  transactions MinistryFundTransaction[]

  @@index([fromFundId])
  @@index([toFundId])
  @@index([createdAt])
}

model LeadershipTerm {
  id              String                    @id @default(uuid())
  assignmentScope LeadershipAssignmentScope
  assignmentId    String
  startedAt       DateTime
  expectedEndAt   DateTime?
  endedAt         DateTime?
  notes           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([assignmentScope, assignmentId])
  @@index([expectedEndAt])
  @@index([endedAt])
  @@index([startedAt])
}

// --- Local Church Operations & Scheduling (MF-7) ---

enum ChurchOperationType {
  SERVICE
  SPECIAL_EVENT
}

enum OperationOccurrenceStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum OperationAssignmentType {
  MAIN_CHOIR
  CHILDREN_CHOIR
  PROTOCOL_TEAM
  SERVICE_TEAM
  CUSTOM
}

enum OperationAssignmentStatus {
  PENDING
  CONFIRMED
  DECLINED
  REPLACED
  COMPLETED
}

enum OperationNotificationKind {
  ASSIGNMENT_CREATED
  ASSIGNMENT_CONFIRMED
  ASSIGNMENT_DECLINED
  OPERATION_PUBLISHED
  OPERATION_CANCELLED
  CONFLICT_DETECTED
}

model OperationTemplate {
  id          String              @id @default(uuid())
  code        String              @unique
  name        String
  type        ChurchOperationType
  description String?
  isSystem    Boolean             @default(false)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  occurrences OperationOccurrence[]
  requirements TemplateAssignmentRequirement[]

  @@index([type, isActive])
}

model TemplateAssignmentRequirement {
  id             String                  @id @default(uuid())
  templateId     String
  assignmentType OperationAssignmentType
  quantity       Int                     @default(1)
  required       Boolean                 @default(true)
  notes          String?

  template OperationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model OperationOccurrence {
  id           String                    @id @default(uuid())
  templateId   String?
  type         ChurchOperationType
  title        String
  description  String?
  startAt      DateTime
  endAt        DateTime
  status       OperationOccurrenceStatus @default(DRAFT)
  createdById  String
  approvedById String?
  publishedAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  template      OperationTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy     User                     @relation("OperationCreator", fields: [createdById], references: [id])
  approvedBy    User?                    @relation("OperationApprover", fields: [approvedById], references: [id])
  requirements  AssignmentRequirement[]
  assignments   OperationAssignment[]
  notifications OperationNotification[]
  protocolTeam  ProtocolOccurrenceTeam?
  choirServiceAssignments ChoirServiceAssignment[]
  choirActivities ChoirActivity[]
  churchServiceRequests ChurchServiceRequest[]
  servicePreparationPlans ServicePreparationPlan[]

  @@index([status])
  @@index([startAt, endAt])
  @@index([type])
  @@index([templateId])
}

model AssignmentRequirement {
  id                    String                  @id @default(uuid())
  operationOccurrenceId String
  assignmentType        OperationAssignmentType
  quantity              Int                     @default(1)
  required              Boolean                 @default(true)
  notes                 String?

  occurrence OperationOccurrence @relation(fields: [operationOccurrenceId], references: [id], onDelete: Cascade)

  @@index([operationOccurrenceId])
}

model OperationAssignment {
  id                 String                    @id @default(uuid())
  occurrenceId       String
  assignmentType     OperationAssignmentType
  operationalUnitId  String
  memberId           String?
  status             OperationAssignmentStatus @default(PENDING)
  confirmedAt        DateTime?
  declinedAt         DateTime?
  notes              String?
  overrideReason     String?
  overrideByUserId   String?
  attendanceId       String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  occurrence      OperationOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  operationalUnit OperationalUnit   @relation(fields: [operationalUnitId], references: [id], onDelete: Restrict)
  member          Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  notifications   OperationNotification[]

  @@unique([occurrenceId, operationalUnitId])
  @@index([occurrenceId, status])
  @@index([operationalUnitId])
  @@index([memberId])
  @@index([attendanceId])
}

model OperationNotification {
  id           String                    @id @default(uuid())
  occurrenceId String?
  assignmentId String?
  userId       String
  kind         OperationNotificationKind
  title        String
  body         String?
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime                  @default(now())

  occurrence OperationOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  assignment OperationAssignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([scheduledFor])
  @@index([occurrenceId])
}


  targetChoirId    String
  status           ChoirDissolutionTransferStatus @default(DRAFT)
  reason           String?
  memberCount      Int?
  executedByUserId String?
  executedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  sourceChoir Choir @relation("DissolutionSource", fields: [sourceChoirId], references: [id])
  targetChoir Choir @relation("DissolutionTarget", fields: [targetChoirId], references: [id])

  @@index([sourceChoirId])
  @@index([targetChoirId])
  @@index([status])
}

model ChoirAttendance {

model ChoirMemberParticipationProfile {
  id                        String   @id @default(uuid())
  choirId                   String
  memberId                  String
  officialServices          Int      @default(0)
  extraServices             Int      @default(0)
  serviceAssignments        Int      @default(0)
  servicesAttended          Int      @default(0)
  serviceAttendanceRate     Float    @default(0)
  rehearsalsScheduled       Int      @default(0)
  rehearsalsAttended        Int      @default(0)
  rehearsalAttendanceRate   Float    @default(0)
  prayerSessionsScheduled   Int      @default(0)
  prayerSessionsAttended    Int      @default(0)
  prayerAttendanceRate      Float    @default(0)
  lateArrivals              Int      @default(0)
  earlyDepartures           Int      @default(0)
  excusedAbsences           Int      @default(0)
  unexcusedAbsences         Int      @default(0)
  overallParticipationScore Float    @default(0)
  lifetimeParticipationScore Float   @default(0)
  yearsActive               Int      @default(0)
  currentRank               Int?
  currentOverallRank        Int?
  statsYear                 Int?
  statsMonth                Int?
  updatedAt                 DateTime @updatedAt

  choir  Choir  @relation(fields: [choirId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  badges ChoirMemberBadge[]

  @@unique([choirId, memberId])
  @@index([choirId, overallParticipationScore])

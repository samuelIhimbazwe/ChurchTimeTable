  eligibleForSunday1      Boolean @default(true)
  eligibleForSunday2      Boolean @default(true)
  eligibleForTuesday      Boolean @default(true)
  eligibleForIgaburo      Boolean @default(true)
  eligibleForSpecialEvents Boolean @default(true)

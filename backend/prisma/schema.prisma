model ServicePreparationItem {
  id          String                     @id @default(uuid())
  planId      String
  itemType    ServicePreparationItemType
  sortOrder   Int                        @default(0)
  title       String
  body        String?
  songId      String?
  scheduledAt DateTime?

  plan ServicePreparationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  song Song?                  @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([itemType])
}

model ChoirDissolutionTransfer {

  activityId       String
  memberId         String
  outcome          ChoirAttendanceOutcome
  scoreEarned      Int?
  notes            String?
  recordedByUserId String?
  recordedAt       DateTime               @default(now())

  activity ChoirActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  member   Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([activityId, memberId])
  @@index([memberId])
  @@index([outcome])

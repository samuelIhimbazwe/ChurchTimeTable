# PostgreSQL (Docker: docker compose up -d)
DATABASE_URL="postgresql://postgres:password@localhost:5432/cmms?schema=public"

# SQLite (local dev without Docker/Postgres password)
# DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="30d"
WEB_ORIGIN="http://localhost:3001,http://127.0.0.1:3001"
PORT=3000
FCM_SERVER_KEY=""
ATTENDANCE_LOCK_HOURS=48

# Public web app URL (WhatsApp deep links, quick-approve links)
WEB_APP_URL="http://localhost:3001"

# WhatsApp Business Cloud API (individual inbox only; disabled by default)
WHATSAPP_ENABLED="false"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"
# Optional Meta-approved template names (omit to send plain text in dev/test)
WHATSAPP_TEMPLATE_THANK_YOU=""
WHATSAPP_TEMPLATE_ANNOUNCEMENT=""
WHATSAPP_TEMPLATE_VERSE=""
WHATSAPP_TEMPLATE_JOIN_REQUEST=""
